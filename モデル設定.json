{
  "version": 1,
  "default": {
    "provider": "cline"
  },
  "providers": {
    "claude": {
      "command": "claude",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "FORCE_COLOR": "0"
      },
      "vars": {
        "model": "claude-haiku-4-5"
      },
      "args": [
        "-p",
        "--output-format",
        "text",
        "--permission-mode",
        "bypassPermissions"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ],
        "maxTurns": [
          "--max-turns",
          "{maxTurns}"
        ]
      }
    },
    "gemini": {
      "command": "gemini",
      "useStdin": false,
      "env": {
        "NO_COLOR": "1",
        "CI": "1"
      },
      "vars": {
        "model": "gemini-3.1-flash-lite-preview",
        "yolo": true
      },
      "args": [],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ],
        "yolo": [
          "--yolo"
        ],
        "prompt": [
          "{prompt}"
        ]
      }
    },
    "cursor": {
      "command": "agent",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "FORCE_COLOR": "0"
      },
      "vars": {
        "model": "GLM-4.7"
      },
      "args": [
        "-p",
        "--output-format",
        "text",
        "--force"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ]
      }
    },
    "codex": {
      "command": "codex",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "CI": "1"
      },
      "vars": {
        "model": "gpt-5"
      },
      "args": [
        "exec",
        "--full-auto"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ]
      }
    },
    "cline": {
      "command": "cline",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "CI": "1"
      },
      "vars": {
        "model": "GLM-5"
      },
      "args": [
        "-y"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ]
      }
    }
  }
}
